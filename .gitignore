# Specify filepatterns you want git to ignore.
!.gitignore
.env
exception.log

*.sublime-workspace

ant.my/app/config/.env
ant.my/app/config/logs/

ant.my/app/sessions/
ant.my/app/smarty/


# .gitignore
ant.my/app/smarty/compile_dir/*
ant.my/app/smarty/cache_dir/*
!ant.my/app/smarty/compile_dir/.gitkeep
!ant.my/app/smarty/cache_dir/.gitkeep

smarty/compile_dir/*
smarty/compile_cache/*
admin/monolog.log
admin/monolog.backup

antCMS.my/admin/core/cache/php/


nix2025.my/smarty/compile_dir/
nix2025.my/smarty/smarty_cache/

