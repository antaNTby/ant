# Specify filepatterns you want git to ignore.
!.gitignore
.env
exception.log

*.sublime-workspace

app/config/.env
app/config/logs/

app/sessions/
app/smarty/


# .gitignore
app/smarty/compile_dir/*
app/smarty/cache_dir/*
!app/smarty/compile_dir/.gitkeep
!app/smarty/cache_dir/.gitkeep

smarty/compile_dir/*
smarty/compile_dir
admin/monolog.log
admin/monolog.backup


